# Copy to .env and fill in your values.

# --- Migaku --------------------------------------------------------------
# Set email + password and the tool will derive the refresh token on first run
# (or run `python -m migaku_supabase login` once to do it explicitly).
MIGAKU_EMAIL=
MIGAKU_PASSWORD=

# Optional. After `login` or first setup, the long-lived refresh token is
# written here so future runs skip the password step.
MIGAKU_REFRESH_TOKEN=

# 32-hex device ID used as `?deviceId=` on /pull-sync and /push/enqueue.
# Auto-generated on first run and persisted here. Do not edit unless you
# want Migaku to treat this install as a new device.
MIGAKU_DEVICE_ID=

# --- Supabase ------------------------------------------------------------
# Project URL from Supabase Project Settings -> API.
SUPABASE_URL=

# Service-role key from Supabase Project Settings -> API.
# Keep this private. It bypasses RLS and is intended for this local sync job.
SUPABASE_SERVICE_ROLE_KEY=

# Destination table. The bundled SQL creates public.migaku_words.
SUPABASE_TABLE=migaku_words

# Optional direct Postgres connection URL. Used only by:
#   python -m migaku_supabase init-db
# or by setup when you choose to apply the schema automatically.
SUPABASE_DB_URL=

# Optional. Override where the tool caches Migaku dict + frequency .db files.
# Defaults to ~/.migaku-supabase/dicts/.
# MIGAKU_SUPABASE_DICTS_DIR=

# --- Sync options --------------------------------------------------------
SYNC_LANG=zh
# Statuses to include. Comma-separated. KNOWN, LEARNING, UNKNOWN, IGNORED, or ALL.
SYNC_STATUS=KNOWN,LEARNING
SYNC_DIFFICULT_LIMIT=2000
